        </mxCell>
        <mxCell id="r9c4" value="读取已解析邮件和事件数据，负责飞书卡片推送、每日摘要、实时事件通知和 RSVP 催办等主动提醒场景。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8FBFF;strokeColor=#B0BEC5;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
