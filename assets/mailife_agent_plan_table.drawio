          <mxGeometry x="420" y="446" width="150" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="r5c4" value="直接查询 PostgreSQL 中的邮件与事件，不依赖 Parser。面向列表、筛选、时间范围、全文搜索。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8FBFF;strokeColor=#B0BEC5;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
