          <mxGeometry x="420" y="954" width="150" height="94" as="geometry"/>
        </mxCell>
        <mxCell id="r11c4" value="reflect_check_node 负责发送前自检；aggregate_and_respond_node 负责把 Query / General / Reply / Meeting / Notification 的输出统一整理给用户。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8FBFF;strokeColor=#B0BEC5;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
