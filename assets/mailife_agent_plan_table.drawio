          <mxGeometry x="420" y="688" width="150" height="94" as="geometry"/>
        </mxCell>
        <mxCell id="r8c4" value="先走 EmailParser 的通用字段提取，再做会议专项提取，生成 RSVP 决策；通过 interrupt 等待用户确认，之后写 DB 并发出 RSVP 回复。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B0BEC5;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
