          <mxGeometry x="420" y="524" width="150" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="r6c4" value="读取最近上下文后直接由 LLM 回答，承接通用问答、兜底问题和闲聊场景。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B0BEC5;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
