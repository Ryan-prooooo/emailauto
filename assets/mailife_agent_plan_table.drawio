        </mxCell>
        <mxCell id="r10c4" value="提供通用解析、摘要、邮件发送、外部系统接入等能力，是 Reply / Meeting / Notification 等业务 Agent 的共享能力底座。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B0BEC5;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
