        </mxCell>
        <mxCell id="r7c4" value="调用 EmailParser.parse_email() 获取摘要，再用 draft_email_reply 生成草稿；通过 interrupt 挂起，等待用户确认后真正发送。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8FBFF;strokeColor=#B0BEC5;fontSize=12;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="570" y="602" width="520" height="86" as="geometry"/>
        </mxCell>
